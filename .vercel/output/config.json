{
  "version": 3,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://travelconcierge.site/api/$1"
    },
    {
      "src": "/sw.js",
      "headers": {
        "cache-control": "no-cache, no-store, must-revalidate",
        "service-worker-allowed": "/"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
